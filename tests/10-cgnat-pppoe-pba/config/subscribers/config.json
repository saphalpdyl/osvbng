{
  "interfaces": {
    "network": [
      {
        "interface": "eth2",
        "address": "10.100.0.2/24",
        "gateway": "10.100.0.1"
      }
    ],
    "access": [
      {
        "interface": "eth1",
        "network-interface": "eth2",
        "type": "pppoe",
        "vlan-mode": "1:1",
        "outer-vlan-min": 200,
        "outer-vlan-max": 200,
        "inner-vlan-min": 2,
        "inner-vlan-max": 6
      }
    ]
  },
  "pppoe": {
    "reconnect": false,
    "discovery-timeout": 5,
    "discovery-retry": 10,
    "host-uniq": true
  },
  "ppp": {
    "lcp": {
      "conf-request-timeout": 5,
      "conf-request-retry": 10,
      "keepalive-retry": 5
    },
    "ipcp": {
      "enable": true
    },
    "ip6cp": {
      "enable": true
    }
  },
  "session-traffic": {
    "ipv4-pps": 10
  },
  "access-line": {
    "agent-circuit-id": "eth 0/2/{session-global}:200.{session-global}",
    "agent-remote-id": "user{session-global}"
  },
  "sessions": {
    "count": 5,
    "max-outstanding": 5,
    "start-rate": 5,
    "stop-rate": 5
  }
}
